# WebSocket server URL (for remote control MVP).
# Default: ws://localhost:3001 when running locally.
# In production, set to your deployed WS server (e.g. wss://ws.yourdomain.com).
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# WebSocket server port (server process only).
# WS_PORT=3001

# Platform owner emails (comma-separated). Any listed email gets
# UserRole.SUPER_ADMIN on login, which unlocks /admin (owner CRM).
# Leave unset in environments that should have no platform owner.
# SYNCBIZ_OWNER_EMAILS=you@example.com,partner@example.com
