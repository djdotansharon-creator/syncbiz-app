# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/server/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local app data (deleted sources, etc.)
/data/
/server/data/

# --- Phase 0: filesystem-backed runtime data (see lib/data-path.ts) ---
# Local dev writes JSON here; Railway uses RAILWAY_VOLUME_MOUNT_PATH (/app/data/...).
# Do not treat bulk JSON as source — avoids accidental `git add .` pollution.
# Kept versioned on purpose: playlists/.gitkeep, playlists/morning-chill.json,
# playlists/m3u/AFRO.m3u, radio/.gitkeep (see negation rules below).
/catalog/*.json
/playlists/*.json
!/playlists/morning-chill.json
/playlists/covers/**
/radio/radio-*.json
/playlists/m3u/*
!/playlists/m3u/AFRO.m3u

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# Exception: production WS URL baked into the desktop installer. Public value,
# no secrets — MUST be committed so CI builds pick it up.
!desktop/.env.electron-web

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local claude settings (per-machine)
.claude/settings.local.json

# desktop runtime binaries (mpv.exe, yt-dlp.exe) — too large for git (100+ MB)
# these are fetched/vendored outside of version control
desktop/resources/
