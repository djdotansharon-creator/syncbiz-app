# Environment overrides baked into the Next.js client bundle that ships INSIDE
# the SyncBiz Desktop installer (`staged-web/`). Loaded by
# `desktop/scripts/build-electron-web.cjs` before `next build`.
#
# These values are embedded at build time into the JS that runs in the Electron
# renderer. They do NOT affect `next dev`, `next start`, or Railway-hosted web
# builds — only the offline bundle packaged into the desktop installer.
#
# When you want to swap to a different production WS host (new Railway service,
# SyncBiz-owned CDN, etc.), change it here and re-run `npm run build:electron-web`
# (or push a `desktop-v*` tag to trigger CI).

# Public WS coordination server. MUST be wss:// in production so the installer,
# which loads over http://localhost:3000 (embedded Next), can still open a
# secure upgrade — mixed content doesn't apply to localhost, but hosted WS
# endpoints are HTTPS-only in practice.
NEXT_PUBLIC_WS_URL=wss://syncbiz-ws-production.up.railway.app
