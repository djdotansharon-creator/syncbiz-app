{
  "name": "syncbiz-player-desktop",
  "productName": "SyncBiz Player",
  "description": "SyncBiz Player — branch station desktop app for scheduled music + remote playback control.",
  "author": {
    "name": "SyncBiz",
    "email": "support@syncbiz.app"
  },
  "homepage": "https://github.com/djdotansharon-creator/syncbiz-app",
  "version": "2.2.1",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.cjs && node scripts/bundle-desktop.cjs",
    "start": "npm run build && electron .",
    "start:web-bundle": "npm run build && node scripts/run-electron-with-staged-web.cjs",
    "verify:player-chrome": "electron scripts/verify-player-chrome.cjs",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "dist": "npm run build && electron-builder",
    "build-icons": "node scripts/build-icons.cjs",
    "dist:win": "npm run build-icons && node scripts/fetch-mpv.cjs && npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.5.13",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.25.0",
    "png2icons": "^2.0.1",
    "sharp": "^0.35.3",
    "to-ico": "^1.1.5",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.syncbiz.player",
    "productName": "SyncBiz Player",
    "copyright": "Copyright (c) 2026 SyncBiz",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "src/renderer/index.html",
      "package.json",
      "!dist/**/*.map"
    ],
    "extraResources": [],
    "asar": true,
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SyncBiz-Player-Setup-${version}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/7zr.exe",
          "to": "7zr.exe"
        },
        {
          "from": "resources/mpv/mpv.exe",
          "to": "mpv.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SyncBiz Player",
      "uninstallDisplayName": "SyncBiz Player"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "SyncBiz-Player-${version}-${arch}.${ext}",
      "category": "public.app-category.music",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SyncBiz-Player-${version}-${arch}.${ext}",
      "category": "AudioVideo"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "djdotansharon-creator",
        "repo": "syncbiz-app",
        "releaseType": "release"
      }
    ]
  }
}
