{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:ws": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:ws\"",
    "build": "next build",
    "build:electron-web": "next build && node desktop/scripts/stage-standalone-for-electron.cjs",
    "desktop:shell": "npm run build:electron-web && npm run build --prefix desktop && node desktop/scripts/run-electron-with-staged-web.cjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "hls.js": "^1.6.15",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "youtube-search-without-api-key": "^2.0.7",
    "youtube-video-parser": "^1.0.4",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
