generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Plan {
  FREE
  PREMIUM
  PROFESSIONAL
  ENTERPRISE
}

enum UserRole {
  SUPER_ADMIN
  WORKSPACE_ADMIN
  MANAGER
  CONTROLLER
  VIEWER
}

/// Lifecycle status for a User row.
/// ACTIVE   – normal account, can authenticate.
/// PENDING  – account exists but cannot authenticate (reserved for a
///            future invite flow; not produced by any current code path).
/// DISABLED – soft-disabled by an admin via DELETE /api/admin/users.
///            Cannot login; existing sessions resolve to null.
enum UserStatus {
  ACTIVE
  PENDING
  DISABLED
}

/// Per-workspace membership lifecycle (workspace-scoped, distinct from global
/// `User.status`).
/// ACTIVE    – membership grants access in this workspace as normal.
/// SUSPENDED – soft-paused: the user remains a workspace member but all
///             tenant/branch role lookups for this workspace return as if no
///             membership exists. The user can still log in globally and use
///             other workspaces. Reversible via "Resume in workspace".
enum MembershipStatus {
  ACTIVE
  SUSPENDED
}

enum DeviceType {
  ELECTRON
  BROWSER
  MPV
}

enum ScheduleStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

enum AiDjStatus {
  IN_PROGRESS
  CONFIRMED
  CANCELLED
}

enum GuestPermission {
  VIEW_ONLY
  ADD_URL
  VOTE
  REQUEST_SONG
}

enum BusinessType {
  RESTAURANT
  GYM
  HOTEL
  BAR
  CAFE
  RETAIL
  OFFICE
  OTHER
}

/// Workspace-level energy preference for Business Profile (Stage 1).
enum WorkspaceEnergyLevel {
  LOW
  MEDIUM
  HIGH
}

/// Stage 2 — playlist discovery beyond the owning workspace (opt-in; default private).
enum PlaylistPublicationScope {
  PRIVATE
  LINK_SHARED
  COMMUNITY_PUBLISHED
  TEMPLATE
  OFFICIAL_SYNCBIZ
  FORK_REMIX
}

/// Stage 3 — Music Taxonomy Dictionary (platform-wide controlled vocabulary).
enum MusicTaxonomyCategory {
  PLAYBACK_CONTEXT
  VIBE_ENERGY
  MAIN_SOUND_GENRE
  STYLE_TAGS
  ISRAELI_SPECIALS
  TECHNICAL_TAGS
  BUSINESS_FIT
  DAYPART_FIT
}

enum MusicTaxonomyTagStatus {
  ACTIVE
  DEPRECATED
  HIDDEN
  MERGED
}

/// Stage 4 — provenance for CatalogItem ↔ taxonomy links (extend later e.g. ML_IMPORT).
enum CatalogItemTaxonomyTagSource {
  MANUAL
}

/// Stage 5.9 — append-only source metadata pulls (SUPER_ADMIN catalog refresh).
enum CatalogSourceFetchStatus {
  SUCCESS
  PARTIAL
  FAILED
}

enum CatalogSourceFetchMethod {
  YOUTUBE_API
  YTDLP
  MANUAL
  UNKNOWN
}

enum AddonType {
  AI_ANNOUNCEMENTS
  MULTI_ZONE
  VIDEO_SCREENS
  EXTRA_USERS
}

/// Lifecycle status for a Workspace, owned by `WorkspaceEntitlement`.
///
/// V1 only sets TRIALING (on signup / backfill) and SUSPENDED (manual admin
/// action, written in Week 2). The remaining values are placeholders for
/// Week 4+ billing integration so we don't need a follow-up enum migration
/// when those code paths land. No code reads non-V1 values today.
enum WorkspaceStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELLED
}

enum TimeSlot {
  MORNING
  AFTERNOON
  EVENING
  NIGHT
}

// ─────────────────────────────────────────────
// STAGE 0 — DISCOVERY / REVIEW (scaffolding)
// ─────────────────────────────────────────────
//
// These enums + `DiscoverySubmission` are scaffolding for the DB-first
// ingestion pipeline (see docs/plan: Stage 0 of the Source/Canonical
// refactor). Nothing reads from these yet — they exist so Stage 1+ can
// land without schema churn. No existing model references them, so this
// migration is purely additive and safe to deploy.

/// Lifecycle state shared by canonical-bound entities (submissions, tags,
/// channels, edit suggestions). Never DELETE — transition through
/// DEPRECATED or REJECTED instead, to keep audit trails intact.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  DEPRECATED
  MERGED
  DUPLICATE
}

/// Where a submission originated. Owner auto-approval rules key off this.
enum SubmissionSource {
  USER
  AI_AGENT
  INTERNET_SEARCH
  IMPORT
}

/// A URL proposed for canonicalization. Every new URL — from a user form,
/// an AI web search, or a bulk import — enters here first. Owner review
/// converts an approved submission into a canonical entry (Stage 2).
///
/// Today this model is write-only for users and read-only for the /admin
/// review-queue UI (Stage 5). No production code path reads/mutates it
/// yet; enforcing that keeps Stage 0 a pure scaffolding migration.
model DiscoverySubmission {
  id String @id @default(uuid())

  /// `null` when the submission came from an autonomous agent (AI search,
  /// scheduled import). Owner reviewers can still trace it via
  /// `submissionSource`.
  submittedById    String?
  submissionSource SubmissionSource

  /// The raw URL as received. We keep both `rawUrl` and (later) the
  /// canonicalized form so we can deduplicate across link shorteners and
  /// tracking params without losing the original user intent.
  rawUrl             String
  resolvedProvider   String?
  resolvedExternalId String?
  /// Snapshot of metadata fetched at ingestion time (title, thumbnail,
  /// durationSec, channel info, etc.). Intentionally `Json` — Stage 2
  /// will formalize fields on the canonical model, this is just a
  /// capture-everything bucket.
  resolvedMetadata   Json?

  suggestedTags  String[]
  suggestedTitle String?
  submitterNote  String?

  status       ReviewStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  /// When status transitions to MERGED / APPROVED, points to the canonical
  /// record that owns this URL going forward. String-typed (not FK) for
  /// Stage 0 because the canonical table doesn't exist yet; Stage 2 will
  /// convert this to a proper relation in the same migration that adds
  /// `CanonicalUrl`.
  mergedIntoId  String?
  duplicateOfId String?

  createdAt DateTime @default(now())

  @@index([status])
  @@index([submittedById])
  @@index([submissionSource])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// IDENTITY & TENANCY
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  name          String?
  firstName     String?
  lastName      String?
  passwordHash  String?
  role          UserRole   @default(CONTROLLER)
  status        UserStatus @default(ACTIVE)
  deactivatedAt DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ownedWorkspaces      Workspace[]            @relation("WorkspaceOwner")
  memberships          WorkspaceMember[]
  branchAssignments    UserBranchAssignment[]
  passwordResetTokens  PasswordResetToken[]
  auditLogs            AuditLog[]
  createdGuestSessions GuestSession[]
  aiDjSessions         AiDjSession[]
  platformAuditActions PlatformAuditLog[]     @relation("PlatformAuditActor")
  catalogTaxonomyTagsCreated CatalogItemTaxonomyTag[] @relation("CatalogTaxonomyTagCreatedBy")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner               User                   @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members             WorkspaceMember[]
  branchAssignments   UserBranchAssignment[]
  branches            Branch[]
  sources             Source[]
  playlists           Playlist[]
  schedules           Schedule[]
  announcements       Announcement[]
  guestSessions       GuestSession[]
  auditLogs           AuditLog[]
  aiDjSessions        AiDjSession[]
  billing             WorkspaceBilling?
  entitlement         WorkspaceEntitlement?
  addons              WorkspaceAddon[]
  announcementChannel AnnouncementChannel?
  platformAuditEvents PlatformAuditLog[]     @relation("PlatformAuditTarget")

  /// Business / music identity for recommendations & catalog intelligence (Stage 1).
  /// Default matching context for the workspace; Branch.businessType remains per-branch and is not auto-synced here.
  businessProfile WorkspaceBusinessProfile?

  @@index([ownerId])
}

/// 1:1 business & music identity for a workspace (source of truth for future tagging / recommendations).
/// Does not replace or sync Branch.businessType — branches may later override for branch-specific context.
model WorkspaceBusinessProfile {
  id                    String              @id @default(uuid())
  workspaceId           String              @unique
  primaryBusinessType   BusinessType        @default(OTHER)
  cuisineOrConcept      String?
  conceptTags           String[]            @default([])
  countryCode           String?
  cultureNotes          String?
  primaryLanguage       String?
  additionalLanguages   String[]            @default([])
  audienceDescriptors   String[]            @default([])
  desiredMoodNotes      String?
  energyLevel           WorkspaceEnergyLevel?
  openingHoursSummary   String?
  openingHoursStructured Json?
  daypartPreferences    Json?
  preferredStyleHints   String[]            @default([])
  blockedStyleHints     String[]            @default([])
  adminNotes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceMember {
  id          String           @id @default(uuid())
  workspaceId String
  userId      String
  role        UserRole         @default(CONTROLLER)
  status      MembershipStatus @default(ACTIVE)
  suspendedAt DateTime?
  createdAt   DateTime         @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

/// User-to-branch access assignment (granular branch scoping for non-owner users).
/// branchId is a plain string (not a FK) to support legacy IDs like "default".
model UserBranchAssignment {
  id          String   @id @default(uuid())
  workspaceId String
  userId      String
  branchId    String
  role        String   @default("BRANCH_CONTROLLER")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, branchId])
  @@index([userId])
  @@index([workspaceId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─────────────────────────────────────────────
// LOCATIONS & DEVICES
// ─────────────────────────────────────────────

model Branch {
  id            String       @id @default(uuid())
  workspaceId   String
  name          String
  code          String       @default("")
  timezone      String       @default("UTC")
  city          String       @default("")
  country       String       @default("")
  status        String       @default("active")
  /// Per-location business label; not auto-synced from WorkspaceBusinessProfile (may become branch-level override vs workspace defaults later).
  businessType  BusinessType @default(OTHER)
  devicesOnline Int          @default(0)
  devicesTotal  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  devices   Device[]
  schedules Schedule[]

  @@index([workspaceId])
}

model Device {
  id              String     @id @default(uuid())
  workspaceId     String
  branchId        String
  name            String
  type            DeviceType @default(ELECTRON)
  deviceKind      String     @default("audio-player")
  token           String     @unique
  isOnline        Boolean    @default(false)
  platform        String     @default("windows")
  deviceStatus    String     @default("offline")
  health          String     @default("ok")
  capabilities    String[]
  lastHeartbeat   String?
  ipAddress       String     @default("")
  agentVersion    String     @default("1.0.0")
  volume          Int        @default(50)
  currentSourceId String?
  lastSeenAt      DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([branchId])
  @@index([token])
}

// ─────────────────────────────────────────────
// MEDIA — WORKSPACE-SCOPED
// ─────────────────────────────────────────────

model Source {
  id                String   @id @default(uuid())
  workspaceId       String
  name              String
  url               String
  type              String
  branchId          String   @default("default")
  description       String?
  capabilities      String[]
  artworkUrl        String?
  isLive            Boolean  @default(false)
  provider          String?
  playerMode        String?
  tags              String[]
  browserPreference String?
  fallbackUriOrPath String?
  taxonomyTags      Json?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  playlistItems PlaylistItem[]

  @@index([workspaceId])
  @@index([branchId])
}

model Playlist {
  id                        String   @id @default(uuid())
  workspaceId               String
  name                      String
  description               String?
  genre                     String   @default("")
  playlistType              String   @default("youtube")
  url                       String   @default("")
  thumbnail                 String   @default("")
  branchId                  String?
  catalogItemId             String?
  viewCount                 Int?
  durationSeconds           Int?
  adminNotes                String?
  useCase                   String?
  useCases                  String[]
  primaryGenre              String?
  subGenres                 String[]
  mood                      String?
  energyLevel               String?
  libraryPlacement          String?
  playlistOwnershipScope    String?
  trackOrder                String[]
  scheduleContributorBlocks Json?
  isShared                  Boolean  @default(false)
  sharedById                String?
  publicationScope          PlaylistPublicationScope @default(PRIVATE)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         PlaylistItem[]
  schedules     Schedule[]
  aiDjPlaylists AiDjPlaylist[]

  @@index([workspaceId])
  @@index([isShared])
  @@index([branchId])
  @@index([publicationScope])
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String
  sourceId   String?
  catalogId  String?
  trackId    String   @default("")
  name       String   @default("")
  trackType  String   @default("youtube")
  url        String   @default("")
  cover      String?
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist     @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  source   Source?      @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  catalog  CatalogItem? @relation(fields: [catalogId], references: [id], onDelete: SetNull)

  @@index([playlistId])
  @@index([sourceId])
  @@index([catalogId])
}

model Schedule {
  id                     String         @id @default(uuid())
  workspaceId            String
  branchId               String
  playlistId             String?
  name                   String?
  cronExpr               String?
  timezone               String         @default("UTC")
  status                 ScheduleStatus @default(ACTIVE)
  targetType             String         @default("SOURCE")
  targetId               String         @default("")
  sourceId               String?
  deviceId               String?
  recurrence             String         @default("weekly")
  oneOffDateLocal        String?
  daysOfWeek             Int[]
  startTimeLocal         String         @default("09:00")
  endTimeLocal           String         @default("23:59")
  enabled                Boolean        @default(true)
  priority               Int            @default(1)
  requestedStartPosition Int?
  requestedEndPosition   Int?
  createdBy              String?
  updatedBy              String?
  taxonomyTags           Json?
  startDate              DateTime?
  endDate                DateTime?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  playlist  Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([branchId])
}

// ─────────────────────────────────────────────
// MUSIC TAXONOMY DICTIONARY (Stage 3) — global, no tenancy
// ─────────────────────────────────────────────

model MusicTaxonomyTag {
  id                  String                   @id @default(uuid())
  slug                String                   @unique
  category            MusicTaxonomyCategory
  labelEn             String
  labelHe             String
  descriptionHeUser   String?                  @db.Text
  descriptionAi       String?                  @db.Text
  aliases             String[]                 @default([])
  status              MusicTaxonomyTagStatus   @default(ACTIVE)
  parentId            String?
  mergedIntoId        String?
  sortOrder           Int                      @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  parent     MusicTaxonomyTag?  @relation("TaxonomyParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   MusicTaxonomyTag[] @relation("TaxonomyParent")
  mergedInto MusicTaxonomyTag?  @relation("TaxonomyMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom MusicTaxonomyTag[] @relation("TaxonomyMerge")
  catalogLinks CatalogItemTaxonomyTag[]

  @@index([category])
  @@index([status])
  @@index([parentId])
  @@index([mergedIntoId])
}

// ─────────────────────────────────────────────
// GLOBAL CATALOG — NO workspaceId
// ─────────────────────────────────────────────

model CatalogItem {
  id            String         @id @default(uuid())
  url           String         @unique
  canonicalUrl  String?        @unique
  videoId       String?
  provider      String?
  title         String
  artist        String?
  durationSec   Int?
  thumbnail     String?
  genres        String[]       @default([])
  businessTypes BusinessType[]
  /// Manual SyncBiz/editorial rating — not YouTube metrics, popularity, or auto-calculated scores.
  curationRating Int           @default(0)
  curationNotes  String?       @db.Text
  addedById     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  playlistItems            PlaylistItem[]
  analytics                CatalogAnalytics?
  playsByBusinessType      CatalogPlayByBusiness[]
  taxonomyLinks            CatalogItemTaxonomyTag[]
  catalogSourceSnapshots   CatalogSourceSnapshot[]

  @@index([videoId])
}

/// Stage 5.9 — append-only provider metadata snapshot per refresh (no automatic CatalogItem overwrite).
model CatalogSourceSnapshot {
  id            String                   @id @default(uuid())
  catalogItemId String
  provider      String?
  sourceUrl     String
  fetchedAt     DateTime                 @default(now())
  fetchStatus   CatalogSourceFetchStatus
  fetchMethod   CatalogSourceFetchMethod
  title         String?
  description   String?                  @db.Text
  hashtags      String[]                 @default([])
  sourceTags    String[]                 @default([])
  channelTitle  String?
  channelId     String?
  publishedAt   DateTime?
  viewCount     Int?
  likeCount     Int?
  commentCount  Int?
  durationSec   Int?
  thumbnail     String?
  rawJson       Json?
  errorMessage  String?                  @db.Text
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([catalogItemId, fetchedAt(sort: Desc)])
}

/// Stage 4 V1 — global manual tagging of catalog rows against the platform taxonomy dictionary.
model CatalogItemTaxonomyTag {
  id             String                       @id @default(uuid())
  catalogItemId  String
  taxonomyTagId  String
  source         CatalogItemTaxonomyTagSource @default(MANUAL)
  confidence     Float?
  createdById    String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  catalogItem CatalogItem      @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  taxonomyTag MusicTaxonomyTag   @relation(fields: [taxonomyTagId], references: [id], onDelete: Cascade)
  createdBy   User?              @relation("CatalogTaxonomyTagCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([catalogItemId, taxonomyTagId])
  @@index([catalogItemId])
  @@index([taxonomyTagId])
}

model CatalogAnalytics {
  id            String    @id @default(uuid())
  catalogItemId String    @unique
  playCount     Int       @default(0)
  lastPlayedAt  DateTime?
  sharedCount   Int       @default(0)
  aiDjCount     Int       @default(0)
  trendingScore Float     @default(0)
  updatedAt     DateTime  @updatedAt

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@index([trendingScore])
  @@index([playCount])
}

model CatalogPlayByBusiness {
  id            String       @id @default(uuid())
  catalogItemId String
  businessType  BusinessType
  playCount     Int          @default(0)
  updatedAt     DateTime     @updatedAt

  catalogItem CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)

  @@unique([catalogItemId, businessType])
  @@index([catalogItemId])
  @@index([businessType])
}

// ─────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────

model WorkspaceBilling {
  id                String    @id @default(uuid())
  workspaceId       String    @unique
  plan              Plan      @default(FREE)
  expiresAt         DateTime?
  maxUrls           Int       @default(10)
  maxBranches       Int       @default(1)
  maxDevices        Int       @default(1)
  maxControllers    Int       @default(2)
  maxPlaylists      Int       @default(5)
  schedulingEnabled Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WorkspaceAddon {
  id          String    @id @default(uuid())
  workspaceId String
  addon       AddonType
  quantity    Int       @default(1)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, addon])
  @@index([workspaceId])
}

/// V1 SaaS lifecycle row: one per Workspace. Single source of truth for
/// trial/active/suspended state and pilot limits. Sits next to the
/// `WorkspaceBilling` row deliberately — billing is plan/payment, this is
/// lifecycle/limits. We keep them separate in V1; if/when paid plans land,
/// the merge (or kept split) is a deliberate decision, not an accident.
///
/// V1 writes this row from two paths only:
///   1. signup — `createWorkspaceOwner` in lib/user-store.ts (30-day trial)
///   2. backfill — scripts/backfill-workspace-entitlements.mjs (60-day grace)
///
/// V1 has NO enforcement code. Reads happen only from `/admin/platform`.
/// Enforcement is Week 3 work and lands behind a feature flag.
model WorkspaceEntitlement {
  id              String          @id @default(uuid())
  workspaceId     String          @unique
  status          WorkspaceStatus @default(TRIALING)
  planCode        String          @default("trial")
  trialEndsAt     DateTime?
  suspendedAt     DateTime?
  suspendedReason String?
  // V1 pilot defaults: 1 branch, up to 4 devices (1 main desktop player +
  // 1 control computer + 1–2 mobile), 5 users, at least 20 playlists.
  // Mirrored explicitly in lib/user-store.ts:ensureWorkspaceEntitlement
  // and scripts/backfill-workspace-entitlements.mjs as defense in depth.
  maxBranches     Int             @default(1)
  maxDevices      Int             @default(4)
  maxUsers        Int             @default(5)
  maxPlaylists    Int             @default(20)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([trialEndsAt])
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  action      String
  entity      String
  entityId    String?
  ipAddress   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Restrict: audit logs must survive user/workspace deletion
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

// ─────────────────────────────────────────────
// PLATFORM ADMIN — V1 SAAS LIFECYCLE
// ─────────────────────────────────────────────

/// Platform-scope audit log for `/admin/platform` actions. Distinct from
/// `AuditLog`, which is workspace-scoped (workspaceId NOT NULL, userId
/// onDelete: Restrict). Platform actions need to survive workspace deletion
/// and may be system-emitted (no actor), so both relations use SetNull.
///
/// V1 creates this table empty. Writes start in Week 2 alongside the first
/// admin mutations (suspend / unsuspend / entitlement edit).
model PlatformAuditLog {
  id                String   @id @default(uuid())
  actorUserId       String?
  targetWorkspaceId String?
  action            String
  metadata          Json?
  ipAddress         String?
  createdAt         DateTime @default(now())

  actor           User?      @relation("PlatformAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetWorkspace Workspace? @relation("PlatformAuditTarget", fields: [targetWorkspaceId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetWorkspaceId])
  @@index([createdAt])
  @@index([action])
}

// ─────────────────────────────────────────────
// GUEST SESSIONS
// ─────────────────────────────────────────────

model GuestSession {
  id          String            @id @default(uuid())
  workspaceId String
  createdById String
  token       String            @unique
  permissions GuestPermission[]
  expiresAt   DateTime
  usedCount   Int               @default(0)
  maxUses     Int?
  createdAt   DateTime          @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([token])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────
// ANNOUNCEMENTS & AUDIO DUCKING
// ─────────────────────────────────────────────

model Announcement {
  id                   String   @id @default(uuid())
  workspaceId          String
  name                 String   @default("")
  text                 String   @default("")
  audioUrl             String?
  voiceId              String?
  durationSec          Int?
  branchId             String   @default("default")
  announcementType     String?
  scheduleId           String?
  announcementStatus   String   @default("draft")
  priority             String   @default("normal")
  ttsEnabled           Boolean  @default(false)
  resumePreviousSource Boolean  @default(false)
  windowStart          String   @default("")
  windowEnd            String   @default("")
  createdAt            DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AnnouncementChannel {
  id             String   @id @default(uuid())
  workspaceId    String   @unique
  defaultVolume  Int      @default(80)
  musicDuckLevel Int      @default(17)
  jingleVolume   Int      @default(90)
  fadeDurationMs Int      @default(500)
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// AI DJ CREATOR
// ─────────────────────────────────────────────

model AiDjSession {
  id           String       @id @default(uuid())
  workspaceId  String
  userId       String
  businessType BusinessType
  hours        Json
  style        String[]
  demographics Json?
  messages     Json
  status       AiDjStatus   @default(IN_PROGRESS)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  playlists AiDjPlaylist[]

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
}

model AiDjPlaylist {
  id         String   @id @default(uuid())
  sessionId  String
  playlistId String?
  slot       TimeSlot
  createdAt  DateTime @default(now())

  session  AiDjSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playlist Playlist?   @relation(fields: [playlistId], references: [id], onDelete: SetNull)

  @@index([sessionId])
}
